# Sanity ────────────────────────────────────────────────────────────────
# From sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Read token (Viewer permissions). Used for draft-mode previews.
SANITY_API_READ_TOKEN=

# Write token (Editor permissions). Used by `npm run seed` only.
SANITY_API_WRITE_TOKEN=

# Used by /api/draft-mode/enable to gate preview links from Sanity Studio.
SANITY_PREVIEW_SECRET=

# Used by /api/revalidate webhook signature verification.
SANITY_REVALIDATE_SECRET=

# Site ──────────────────────────────────────────────────────────────────
# Used for absolute URLs in metadata, sitemap, robots.txt
NEXT_PUBLIC_SITE_URL=https://petejenkins.co.uk

# Flickr ────────────────────────────────────────────────────────────────
# Public user ID, e.g. 203368911@N04 (visible in your Flickr profile URL).
# Uses the public photostream feed — no API key or Pro account required.
NEXT_PUBLIC_FLICKR_USER_ID=

# Instagram (Creator/Business account only) ────────────────────────────
# Long-lived access token from your Meta Developer app. Expires every 60
# days — refresh manually or via /api/instagram/refresh-token.
INSTAGRAM_ACCESS_TOKEN=
# Used only for the "Follow on Instagram" link, no API access needed.
NEXT_PUBLIC_INSTAGRAM_USERNAME=petejenkinssss

# Resend (optional — wire up later) ─────────────────────────────────────
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=hello@petejenkins.co.uk
